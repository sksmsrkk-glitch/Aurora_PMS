{
  "name": "aurora-hotel-pms",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "npm run build && npm run test:unit",
    "test:unit": "node --test tests/*.test.mjs",
    "test:integration": "node --test tests/postgres-*.integration.mjs",
    "test:ci": "npm run lint && npm run build && npm run test:unit && npm run test:integration",
    "qa:workflow": "node scripts/qa-full-workflow.mjs",
    "qa:booking": "node scripts/qa-booking-engine.mjs",
    "qa:website": "node scripts/qa-website-cms.mjs",
    "benchmark": "node tests/api-benchmark.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern work",
    "db:supabase:migrate": "node scripts/migrate-supabase.mjs",
    "db:supabase:smoke": "node scripts/smoke-supabase.mjs",
    "db:provision-role": "node scripts/provision-role.mjs",
    "db:test:bootstrap": "node scripts/bootstrap-test-postgres.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "fflate": "^0.8.2",
    "jose": "6.2.3",
    "next": "^16.2.10",
    "postgres": "^3.4.9",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "type": "module"
}
