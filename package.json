{
  "name": "talos-hotel-pms",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "release:build": "npm run db:contract:static && next build",
    "release:staging": "node scripts/assert-staging-db-target.mjs && node scripts/preflight-saas-migration.mjs && node scripts/migrate-supabase.mjs && node scripts/run-staging-db-integration.mjs && npm run db:contract:verify && npm run release:build",
    "start": "next start",
    "test": "npm run build && npm run test:unit",
    "test:unit": "node --import tsx --test tests/*.test.mjs",
    "test:integration": "node --import tsx --test tests/postgres-*.integration.mjs",
    "test:ci": "npm run lint && npm run build && npm run test:unit && npm run docs:metrics:check && npm run test:integration",
    "qa:workflow": "node scripts/qa-full-workflow.mjs",
    "qa:booking": "node scripts/qa-booking-engine.mjs",
    "qa:website": "node scripts/qa-website-cms.mjs",
    "qa:staff": "node scripts/qa-staff-access.mjs",
    "qa:public": "node scripts/qa-public-site.mjs",
    "benchmark": "node tests/api-benchmark.mjs",
    "benchmark:search": "node --import tsx scripts/benchmark-search.mjs",
    "docs:metrics": "node --import tsx scripts/generate-project-metrics.mjs",
    "docs:metrics:check": "npm run docs:metrics && git diff --exit-code -- docs/generated/project-metrics.md",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern work",
    "db:supabase:migrate": "node scripts/migrate-supabase.mjs",
    "db:supabase:smoke": "node scripts/smoke-supabase.mjs",
    "db:saas:preflight": "node scripts/preflight-saas-migration.mjs",
    "qa:staging:db": "node scripts/run-staging-db-integration.mjs",
    "qa:staging:cleanup-residue": "node scripts/cleanup-staging-integration-residue.mjs",
    "db:provision-role": "node --import tsx scripts/provision-role.mjs",
    "ops:platform-operator": "node scripts/manage-platform-operator.mjs",
    "ops:tenant:provision": "node --import tsx scripts/provision-tenant.mjs",
    "db:test:bootstrap": "node scripts/bootstrap-test-postgres.mjs",
    "db:contract:verify": "node --import tsx scripts/verify-runtime-contract.mjs",
    "db:contract:static": "node --import tsx scripts/verify-static-schema-contract.mjs"
  },
  "dependencies": {
    "@expo-google-fonts/noto-sans-kr": "^0.4.3",
    "@pdf-lib/fontkit": "^1.1.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.14.7",
    "fflate": "^0.8.2",
    "jose": "6.2.3",
    "next": "^16.2.10",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.9",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.19",
    "sharp": "0.35.3"
  },
  "type": "module"
}
