# Aurora runtime. Never commit real credentials.
DATABASE_URL=postgresql://pooled-runtime
DIRECT_URL=postgresql://direct-migrations
SUPABASE_URL=https://PROJECT.supabase.co
SUPABASE_SECRET_KEY=replace-me
PMS_SESSION_SECRET=replace-with-at-least-32-random-characters
PMS_RATE_LIMIT_SECRET=replace-with-at-least-32-random-characters
PMS_ENVIRONMENT=development

# Multi-hotel routing and public sites.
AURORA_PUBLIC_PROPERTY_ID=prop-seoul
AURORA_PUBLIC_SITE_URL=https://pms.example.com/hotel
AURORA_PLATFORM_HOSTS=pms.example.com
AURORA_TENANT_BASE_DOMAIN=hotels.example.com

# Control-plane security and durable worker.
PMS_REQUIRE_PLATFORM_MFA=true
CRON_SECRET=replace-with-random-secret
AURORA_WORKER_URL=https://pms.example.com/api/internal/worker
AURORA_WORKER_BATCH_SIZE=10
AURORA_OUTBOUND_HOST_ALLOWLIST=webhooks.example.com,backup.example.com

# Vendor-neutral backup and provider adapters.
AURORA_BACKUP_ORCHESTRATOR_URL=https://backup.example.com/aurora/jobs
AURORA_BACKUP_ORCHESTRATOR_SECRET=replace-me
AURORA_CHANNEL_PROVIDER_ENDPOINT=https://channel.example.com/ari
AURORA_CHANNEL_PROVIDER_SECRET=replace-me
